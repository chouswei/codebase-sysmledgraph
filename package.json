{
  "name": "sysmledgraph",
  "version": "0.8.2",
  "description": "Path-only SysML indexer: knowledge graph (Kuzu), MCP server (query, context, impact, rename, cypher), CLI (analyze, list, clean)",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "sysmledgraph": "dist/bin/cli.js",
    "sysmledgraph-mcp": "dist/mcp/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^12.0.0",
    "fast-glob": "^3.3.2",
    "kuzu": "^0.11.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "sysml-v2-lsp": "^0.8.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "keywords": [
    "sysml",
    "knowledge-graph",
    "mcp",
    "kuzu",
    "indexer"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chouswei/codebase-sysmledgraph.git"
  },
  "files": [
    "dist",
    "scripts",
    "lsp/package.json",
    "lsp/package-lock.json",
    "lsp/README.md",
    "lsp/test-server.mjs",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "node scripts/clean.mjs",
    "test": "vitest run",
    "test:daemon": "vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "worker:daemon": "node dist/src/worker/daemon.js",
    "analyze": "node dist/bin/cli.js analyze",
    "export-graph": "node dist/bin/cli.js graph export",
    "generate-map": "node dist/bin/cli.js graph map",
    "index-and-map": "node scripts/index-and-map.mjs",
    "deploy-skills": "node scripts/deploy-skills.mjs",
    "mcp": "node dist/mcp/index.js",
    "smoke:mcp": "node scripts/smoke-sysmledgraph-mcp.mjs",
    "check:sysml-lsp": "node scripts/check-sysml-v2-lsp-version.mjs",
    "setup-lsp": "node scripts/setup-lsp.mjs",
    "prepublishOnly": "npm run build"
  }
}
